        path(d='M5.08965 7.28953C6.62959 7.2935 7.32012 8.01568 8.35785 8.40118C8.48084 8.44666 10.0618 7.36909 10.6857 7.29017C12.3755 7.07673 12.6523 7.71718 13.8258 8.52392C14.5266 8.31663 15.6412 7.27979 16.1498 7.27197C22.79 7.16961 18.903 15.6256 20.5903 19.3089C20.7594 19.6772 21.2923 20.0842 21.6229 20.3547L21.227 19.1787C21.0515 18.647 21.0079 18.441 21.2437 17.9734C21.6588 17.7937 21.441 17.8375 21.9278 17.8873C22.5722 18.369 23.0719 20.7235 23.3153 21.601C22.3198 22.017 20.2482 22.9425 19.3002 22.42C19.1541 21.9616 19.1528 22.1815 19.272 21.7377C19.6563 21.3927 20.1688 21.3208 20.6877 21.1838C18.0036 18.9623 18.8902 14.6095 18.9004 11.2471C18.8594 8.32393 16.1357 7.57791 14.6035 10.0298C14.4343 12.8961 14.7008 15.8392 14.4856 18.7005C14.4587 19.0529 14.401 19.0866 14.1422 19.261C13.6452 19.3035 13.7105 19.3783 13.3633 19.1722C12.6766 17.4203 14.1999 10.1271 12.4242 9.07481C6.80767 5.7451 9.83117 17.7639 8.63073 19.2813C8.24639 19.3505 8.24767 19.3769 7.88255 19.2017C7.30731 18.4533 7.6955 17.8667 7.62247 17.0451C7.44951 15.1162 8.21565 10.5597 6.97678 9.17064C6.63087 8.78271 5.39327 8.71878 4.90387 8.18736C4.84494 7.6731 4.86673 7.82659 5.08965 7.28953Z' fill='url(#girlsZodiacGrad)')
        defs
            linearGradient#girlsZodiacGrad(x1='22.5' y1='2.5' x2='3.5' y2='24' gradientUnits='userSpaceOnUse')
                stop(stop-color='#FFD698')
                stop(offset='0.362284' stop-color='#F1B965')
                stop(offset='1' stop-color='#BA8D4A')

mixin girls-select()
    //- ============================================================
    //- ИСТОЧНИК ДАННЫХ — В РАЗМЕТКЕ (для бэкенда / Bitrix), по образцу girls-detail.
    //- Каждый слайд .swiper-slide несёт поля девушки в data-* атрибутах
    //- (data-name/age/params/zodiac/stats[JSON]). JS НИЧЕГО не хранит — только
    //- читает их из DOM и обновляет ОДНУ инфо-карточку при смене слайда.
    //- Бэкенд заменяет цикл `each girl in girls` своим выводом из Bitrix,
    //- сохраняя те же классы и data-атрибуты — JS продолжит работать.
    //- ============================================================
    -
        const girls = [
            {
                name: 'мерседес',
                photo: PUBLIC + 'assets/img/girls/mercedes.png',
                age: '22 года',
                params: '90 / 57 / 82',
                zodiac: 'скорпион',
                stats: [
                    { label: 'Скромность', value: 20 },
                    { label: 'Обаяние', value: 80 },
                    { label: 'Темперамент', value: 100 },
                    { label: 'Напористость', value: 50 }
                ]
            },
            {
                name: 'анжелика',
                photo: PUBLIC + 'assets/img/girls/angelika.png',
                age: '24 года',
                params: '88 / 60 / 90',
                zodiac: 'скорпион',
                stats: [
                    { label: 'Скромность', value: 40 },
                    { label: 'Обаяние', value: 90 },
                    { label: 'Темперамент', value: 80 },
                    { label: 'Напористость', value: 70 }
                ]
            },
            {
                name: 'виктория',
                photo: PUBLIC + 'assets/img/girls/viktoriya.png',
                age: '23 года',
                params: '92 / 58 / 88',
                zodiac: 'скорпион',
                stats: [
                    { label: 'Скромность', value: 30 },
                    { label: 'Обаяние', value: 100 },
                    { label: 'Темперамент', value: 90 },
                    { label: 'Напористость', value: 60 }
                ]
            }
        ];
        //- Инфо-карточка рендерится для первой девушки; дальше её обновляет JS.
        const first = girls[0];
        //- Стат-блок раскладываем 2×2 (на мобиле CSS делает 1 колонку).
        const firstRows = [first.stats.slice(0, 2), first.stats.slice(2, 4)];

    section.girls-select
        .girls-select__header.container
            +badge({text: 'девушки'})
            p.girls-select__lead Красивейшие артистки, каждая со своим уникальным характером, ролью и внешностью. <br> Настоящая магия приватного разговора

        .girls-select__main
            //- Сцена: свет + фото + стрелки. position:relative — точка отсчёта: стрелки
            //- центрируются по фото (top:50%), свет — по фигуре. Имя инфо-карточки заходит
            //- на низ фото (Figma) через отрицательный margin у .girls-select__info-stack.
            .girls-select__stage
                .girls-select__glow(aria-hidden='true')

                //- Слайды — ЕДИНЫЙ источник данных: каждый несёт поля девушки в data-*.
                .girls-select__swiper
                    .swiper-wrapper
                        each girl in girls
                            .swiper-slide(
                                data-name=girl.name
                                data-age=girl.age
                                data-params=girl.params
                                data-zodiac=girl.zodiac
                                data-stats=JSON.stringify(girl.stats)
                            )
                                .girls-select__photo
                                    img(src=girl.photo alt=girl.name loading='lazy')

                //- Соединительная линия — отдельным слоем ПОД фото (Figma: слой «стрелки»
                //- ниже «фото»), чтобы уходить за фигуру девушки и быть видимой только по краям.
                span.girls-select__nav-line(aria-hidden='true')

                .girls-select__nav
                    button.girls-select__nav-btn.girls-select__nav-btn--prev.btn-reset(type='button' aria-label='Предыдущая')
                        span.girls-select__nav-ico.is-desktop
                            +svg('arrow-l')
                        +girlsNavArrow('prev')
                    button.girls-select__nav-btn.girls-select__nav-btn--next.btn-reset(type='button' aria-label='Следующая')
                        span.girls-select__nav-ico.is-desktop
                            +svg('arrow-l')
                        +girlsNavArrow('next')

            //- ОДНА инфо-карточка — JS обновляет её поля из data-* активного слайда.
            .girls-select__info-stack
                .girls-select__info.is-active
                    .girls-select__name-row
                        h3.girls-select__name= first.name
                        span.girls-select__zodiac-icon(aria-hidden='true')
                            +girlsZodiac()

                    .girls-select__meta
                        span.girls-select__meta-item= first.age
                        span.girls-select__meta-divider
                        span.girls-select__meta-item= first.params
                        span.girls-select__meta-divider
                        span.girls-select__meta-item= first.zodiac

                    .girls-select__stats
                        each row in firstRows
                            .girls-select__stats-row
                                each stat in row
                                    .girls-select__stat
                                        .girls-select__stat-head
                                            span.girls-select__stat-label= stat.label
                                            span.girls-select__stat-value #{stat.value}%
                                        .girls-select__stat-bar
                                            span.girls-select__stat-fill(style=`width: ${stat.value}%`)
